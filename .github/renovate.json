{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "packageRules": [
    {
      "description": "Group and auto-merge non-major GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions dependencies",
      "automerge": true,
      "automergeType": "pr",
      // Match all packages captured by this manager
      "matchPackagePatterns": [
        "*"
      ],
      // Explicitly exclude v4 actions from this specific rule's scope
      "excludePackagePatterns": [
        "^actions/.+@v4/"
      ],
      "allowedVersions": "!/^v4\\./"
    },
    {
      "description": "Terraform Provider Updates",
      "matchManagers": [
        "terraform"
      ],
      "matchPackagePatterns": [
        "^registry\\.terraform\\.io/.+"
      ],
      "groupName": "Terraform Provider Updates",
      "major": {
        "automerge": false,
        "labels": [
          "renovate/major"
        ]
      },
      "minor": {
        "automerge": true,
        "automergeType": "pr"
      },
      "patch": {
        "automerge": true,
        "automergeType": "pr"
      }
    }
  ]
}
