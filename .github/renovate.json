{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "packageRules": [
    {
      "description": "Group and auto-merge non-major GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions dependencies",
      "automerge": true,
      "automergeType": "pr",
      // Exclude v4 actions matching this regex cleanly using the dedicated array
      "excludePackageNames": [
        "/^actions/.+@v4/"
      ],
      "allowedVersions": "!/^v4\\./"
    },
    {
      "description": "Terraform Provider Updates",
      "matchManagers": [
        "terraform"
      ],
      // Use standard regex matching syntax wrapped in forward slashes for literals
      "matchPackageNames": [
        "/^registry\\.terraform\\.io/.+/"
      ],
      "groupName": "Terraform Provider Updates",
      "major": {
        "automerge": false,
        "labels": [
          "renovate/major"
        ]
      },
      "minor": {
        "automerge": true,
        "automergeType": "pr"
      },
      "patch": {
        "automerge": true,
        "automergeType": "pr"
      }
    }
  ]
}
